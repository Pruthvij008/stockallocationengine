# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/investify

# Secret used to sign JWTs (use a long random value in production)
JWT_KEY=change-me-to-a-long-random-secret

# URL of the Flask ML service (fly.py)
FLASK_SERVER_URL=http://localhost:5000

# Port the Express server listens on
PORT=8080

# Origin allowed by CORS (the frontend dev server)
CLIENT_ORIGIN=http://localhost:5173

# Only needed by flyprev.py (the earlier FRED-based ML variant)
FRED_API_KEY=your-fred-api-key
